                "open_by_default": false,
                "icon": "none",
                "width": 20
              },
              "blocks": {
                "text_QzN6JM": {
                  "type": "text",
                  "settings": {
                    "text": "<p>We are very sorry that the product did not work for you! We proudly offer a 30-day money back guarantee of the purchase price of the item excluding a restocking fee. Please email our support team at <a href=\"mailto:support@alphapaw.com\" target=\"_self\">support@alphapaw.com</a> for assistance with your return.</p>",
                    "width": "100%",
                    "max_width": "none",
