{% comment %}
  Section: Review Video Grid
  A grid of customer video reviews with thumbnails.
{% endcomment %}

<div id="ReviewVideoGrid-{{ section.id }}" class="review-video-grid-wrapper">
  <section class="section-inner">
    <div class="header-content" style="text-align: {{ section.settings.header_align }};">
      <span class="section-tag" style="color: {{ section.settings.tag_color }};">{{ section.settings.tag }}</span>
      <h2 class="section-title" style="color: {{ section.settings.heading_color }};">{{ section.settings.heading }}</h2>
      <p class="section-sub" style="color: {{ section.settings.subtext_color }};">{{ section.settings.subtext }}</p>
    </div>

    <div class="video-grid">
      {% for block in section.blocks %}
        <div class="video-card" style="background-color: {{ section.settings.card_bg }}; border-color: {{ section.settings.card_border }};" {{ block.shopify_attributes }}>
          <div class="video-thumb-wrap">
            {% if block.settings.thumbnail != blank %}
              <img class="video-thumb" src="{{ block.settings.thumbnail | image_url: width: 800 }}" alt="{{ block.settings.author }}">
            {% else %}
              <div class="video-thumb-placeholder"></div>
            {% endif %}
            <div class="video-play"></div>
          </div>
          <div class="video-info">
            <div class="video-stars" style="color: {{ section.settings.star_color }};">{{ block.settings.stars }}</div>
            <div class="video-quote" style="color: {{ section.settings.quote_color }};">"{{ block.settings.quote }}"</div>
            <div class="video-author" style="color: {{ section.settings.heading_color }};">{{ block.settings.author }}</div>
            <div class="video-product" style="color: {{ section.settings.tag_color }};">{{ block.settings.product }}</div>
          </div>
        </div>
      {% endfor %}
    </div>
  </section>
</div>

<style>
  #ReviewVideoGrid-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .video-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-top: 40px;
  }

  .video-card {
    border-radius: 20px;
    overflow: hidden;
    border: 1px solid;
    position: relative;
    cursor: pointer;
    display: flex;
    flex-direction: column;
  }

  .video-thumb-wrap {
    position: relative;
    overflow: hidden;
  }

  .video-thumb, .video-thumb-placeholder {
    width: 100%;
    height: 240px;
    object-fit: cover;
    display: block;
    transition: transform 0.4s;
    background-color: #eee;
  }

  .video-card:hover .video-thumb {
    transform: scale(1.05);
  }

  .video-play {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.95);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.2s, background 0.2s;
    box-shadow: 0 10px 25px rgba(0,0,0,0.1);
  }

  .video-card:hover .video-play {
    transform: translate(-50%, -50%) scale(1.1);
    background: white;
  }

  .video-play::after {
    content: '';
    width: 0;
    height: 0;
    border-top: 10px solid transparent;
    border-bottom: 10px solid transparent;
    border-left: 18px solid #1C3A2F;
    margin-left: 4px;
  }

  .video-info {
    padding: 24px;
    flex: 1;
  }

  .video-stars {
    font-size: 14px;
    margin-bottom: 8px;
  }

  .video-quote {
    font-size: 14px;
    line-height: 1.6;
    font-style: italic;
    margin-bottom: 12px;
  }

  .video-author {
    font-size: 14px;
    font-weight: 600;
  }

  .video-product {
    font-size: 12px;
    margin-top: 4px;
  }

  @media (max-width: 960px) {
    .video-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

{% schema %}
{
  "name": "Review Video Grid",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Background Color", "default": "#FFFFFF" },
    { "type": "text", "id": "tag", "label": "Tag", "default": "Video Reviews" },
    { "type": "color", "id": "tag_color", "label": "Tag Color", "default": "#4A7C59" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Watch Them Unbox the Joy" },
    { "type": "color", "id": "heading_color", "label": "Heading Color", "default": "#1A1A1A" },
    { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "Nothing beats a real reaction. Watch customers open their personalized orders." },
    { "type": "color", "id": "subtext_color", "label": "Subtext Color", "default": "#4A4A4A" },
    { "type": "select", "id": "header_align", "label": "Header Alignment", "options": [
      { "value": "left", "label": "Left" },
      { "value": "center", "label": "Center" }
    ], "default": "left" },
    { "type": "color", "id": "card_bg", "label": "Card BG", "default": "#FFFFFF" },
    { "type": "color", "id": "card_border", "label": "Card Border", "default": "rgba(74,124,89,0.15)" },
    { "type": "color", "id": "star_color", "label": "Star Color", "default": "#E8A020" },
    { "type": "color", "id": "quote_color", "label": "Quote Color", "default": "#4A4A4A" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 5, "unit": "px", "label": "Padding Top", "default": 80 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 5, "unit": "px", "label": "Padding Bottom", "default": 80 }
  ],
  "blocks": [
    {
      "type": "video_review",
      "name": "Video Review",
      "settings": [
        { "type": "image_picker", "id": "thumbnail", "label": "Video Thumbnail" },
        { "type": "text", "id": "stars", "label": "Stars Text", "default": "★★★★★" },
        { "type": "textarea", "id": "quote", "label": "Quote", "default": "I was not expecting this level of quality. It honestly looks like a painting." },
        { "type": "text", "id": "author", "label": "Author Name", "default": "Kelly M. — @kellyandherdogs" },
        { "type": "text", "id": "product", "label": "Product Name", "default": "Custom Pet Portrait" },
        { "type": "url", "id": "video_url", "label": "Video URL" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Review Video Grid",
      "blocks": [
        { "type": "video_review" },
        { "type": "video_review" },
        { "type": "video_review" }
      ]
    }
  ]
}
{% endschema %}
