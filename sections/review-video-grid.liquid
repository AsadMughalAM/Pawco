{% comment %}
  Section: Review Video Grid (Playful Pet Master Style)
  A grid of customer video reviews with bold playful cards and hard shadows.
{% endcomment %}

<div id="ReviewVideoGrid-{{ section.id }}" class="review-video-grid-wrapper">
  <section class="section-inner">
    <div class="header-content" style="text-align: {{ section.settings.header_align }};">
      <span class="section-tag-playful" style="background-color: {{ section.settings.tag_color }}; color: #fff;">{{ section.settings.tag }}</span>
      <h2 class="section-title" style="color: {{ section.settings.heading_color }};">{{ section.settings.heading }}</h2>
      <p class="section-sub" style="color: {{ section.settings.subtext_color }};">{{ section.settings.subtext }}</p>
    </div>

    <div class="video-grid-playful">
      {% for block in section.blocks %}
        <div class="video-card-playful" {{ block.shopify_attributes }}>
          <div class="video-thumb-container">
            {% if block.settings.thumbnail != blank %}
              <img class="video-thumb" src="{{ block.settings.thumbnail | image_url: width: 800 }}" alt="{{ block.settings.author }}">
            {% else %}
              <div class="video-thumb-placeholder"></div>
            {% endif %}
            <div class="play-btn-playful">
              <div class="play-icon"></div>
            </div>
          </div>
          
          <div class="video-info">
            <div class="video-stars" style="color: {{ section.settings.star_color }};">{{ block.settings.stars }}</div>
            <div class="video-quote" style="color: {{ section.settings.quote_color }};">"{{ block.settings.quote }}"</div>
            
            <div class="video-author-info">
              <div class="video-author" style="color: {{ section.settings.heading_color }};">{{ block.settings.author }}</div>
              <div class="video-product" style="color: {{ section.settings.tag_color }};">{{ block.settings.product }}</div>
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
  </section>
</div>

<style>
  #ReviewVideoGrid-{{ section.id }} {
    --dark: #1A1A2E;
    --font-heading: 'Fredoka', 'Outfit', sans-serif;
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    position: relative;
    overflow: hidden;
  }

  .section-tag-playful {
    display: inline-block;
    padding: 6px 15px;
    border-radius: 50px;
    font-weight: 800;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 20px;
    border: 2px solid var(--dark);
    box-shadow: 3px 3px 0px var(--dark);
  }

  .section-title {
    font-family: var(--font-heading);
    font-size: clamp(32px, 5vw, 55px);
    font-weight: 900;
    line-height: 1.1;
    margin-bottom: 20px;
    letter-spacing: -1.5px;
  }

  .section-sub {
    font-size: 20px;
    line-height: 1.6;
    max-width: 650px;
    margin-bottom: 50px;
    font-weight: 500;
    opacity: 0.8;
  }

  .video-grid-playful {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 40px;
    margin-top: 40px;
  }

  .video-card-playful {
    border-radius: 35px;
    border: 3px solid var(--dark);
    overflow: hidden;
    background: #fff;
    box-shadow: 12px 12px 0px var(--dark);
    transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    display: flex;
    flex-direction: column;
    cursor: pointer;
  }

  .video-card-playful:hover {
    transform: translate(-4px, -4px);
    box-shadow: 18px 18px 0px var(--dark);
  }

  .video-thumb-container {
    position: relative;
    overflow: hidden;
    height: 260px;
    border-bottom: 3px solid var(--dark);
  }

  .video-thumb {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .video-card-playful:hover .video-thumb {
    transform: scale(1.05);
  }

  .play-btn-playful {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 70px;
    height: 70px;
    border-radius: 50%;
    background: #FFFFFF;
    border: 3px solid var(--dark);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 4px 4px 0px var(--dark);
    transition: all 0.2s ease;
    z-index: 5;
  }

  .video-card-playful:hover .play-btn-playful {
    transform: translate(-50%, -50%) scale(1.1);
    box-shadow: 6px 6px 0px var(--dark);
  }

  .play-icon {
    width: 0;
    height: 0;
    border-top: 12px solid transparent;
    border-bottom: 12px solid transparent;
    border-left: 20px solid var(--dark);
    margin-left: 5px;
  }

  .video-info {
    padding: 30px;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .video-stars {
    font-size: 16px;
    margin-bottom: 15px;
    letter-spacing: 1px;
  }

  .video-quote {
    font-size: 16px;
    line-height: 1.6;
    font-weight: 600;
    font-style: italic;
    margin-bottom: 25px;
    flex: 1;
    color: #444;
  }

  .video-author-info {
    padding-top: 20px;
    border-top: 2px dashed rgba(0,0,0,0.1);
  }

  .video-author {
    font-family: var(--font-heading);
    font-size: 16px;
    font-weight: 900;
  }

  .video-product {
    font-size: 13px;
    font-weight: 700;
    margin-top: 5px;
  }

  @media (max-width: 1024px) {
    .video-grid-playful {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .video-grid-playful {
      grid-template-columns: 1fr;
    }
  }
</style>

{% schema %}
{
  "name": "Review Video Grid",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Background Color", "default": "#FFFFFF" },
    { "type": "text", "id": "tag", "label": "Tag", "default": "Video Reviews" },
    { "type": "color", "id": "tag_color", "label": "Tag Color", "default": "#4A7C59" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Watch Them Unbox the Joy" },
    { "type": "color", "id": "heading_color", "label": "Heading Color", "default": "#1A1A2E" },
    { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "Nothing beats a real reaction. Watch customers open their personalized orders." },
    { "type": "color", "id": "subtext_color", "label": "Subtext Color", "default": "#4A4A4A" },
    { "type": "select", "id": "header_align", "label": "Header Alignment", "options": [
      { "value": "left", "label": "Left" },
      { "value": "center", "label": "Center" }
    ], "default": "left" },
    { "type": "color", "id": "star_color", "label": "Star Color", "default": "#E8A020" },
    { "type": "color", "id": "quote_color", "label": "Quote Color", "default": "#1A1A2E" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 5, "unit": "px", "label": "Padding Top", "default": 100 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 5, "unit": "px", "label": "Padding Bottom", "default": 100 }
  ],
  "blocks": [
    {
      "type": "video_review",
      "name": "Video Review",
      "settings": [
        { "type": "image_picker", "id": "thumbnail", "label": "Video Thumbnail" },
        { "type": "text", "id": "stars", "label": "Stars Text", "default": "★★★★★" },
        { "type": "textarea", "id": "quote", "label": "Quote", "default": "I was not expecting this level of quality. It honestly looks like a painting." },
        { "type": "text", "id": "author", "label": "Author Name", "default": "Kelly M. — @kellyandherdogs" },
        { "type": "text", "id": "product", "label": "Product Name", "default": "Custom Pet Portrait" },
        { "type": "url", "id": "video_url", "label": "Video URL" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Review Video Grid",
      "blocks": [
        { "type": "video_review" },
        { "type": "video_review" },
        { "type": "video_review" }
      ]
    }
  ]
}
{% endschema %}
