{% comment %}
  Section: Review Hero (Playful Pet Master Style)
  A high-impact hero with aggregate rating and playful decorative elements.
{% endcomment %}

<div id="ReviewHero-{{ section.id }}" class="review-hero-wrapper">
  <div class="impact-dot impact-dot-1"></div>
  <div class="impact-dot impact-dot-2"></div>

  <section class="review-hero-inner section-inner">
    <div class="hero-main-content">
      <div class="review-badge" style="background-color: {{ section.settings.badge_bg }}; color: {{ section.settings.badge_color }};">
        {{ section.settings.badge_text }}
      </div>

      <h1 class="hero-title" style="color: {{ section.settings.text_color }};">
        {{ section.settings.heading_main }}<br>
        <span class="hero-highlight" style="color: {{ section.settings.highlight_color }};">{{ section.settings.heading_italic }}</span>
      </h1>
      
      <p class="hero-subtext" style="color: {{ section.settings.text_color }}; opacity: 0.9;">
        {{ section.settings.subtext }}
      </p>

      <div class="hero-actions">
        <a href="#ReviewGrid-{{ section.id }}" class="btn-primary-playful" style="background-color: {{ section.settings.highlight_color }}; color: #1A1A2E;">
          Read Our Stories
        </a>
      </div>
    </div>

    <div class="hero-stats-card fade-up">
      <div class="stats-header">
        <div class="big-score" style="color: {{ section.settings.highlight_color }};">{{ section.settings.score }}</div>
        <div class="stars-wrap">
          <div class="stars" style="color: {{ section.settings.star_color }};">★★★★★</div>
          <div class="total-revs" style="color: {{ section.settings.text_color }};">{{ section.settings.review_count_text }}</div>
        </div>
      </div>

      <div class="rating-bars">
        {% for block in section.blocks %}
          {% if block.type == 'rating_bar' %}
            <div class="rating-bar-row" {{ block.shopify_attributes }}>
              <span class="bar-label">{{ block.settings.label }}</span>
              <div class="bar-track" style="background-color: {{ section.settings.bar_track_color }};">
                <div class="bar-fill" style="width: {{ block.settings.percentage }}%; background-color: {{ section.settings.star_color }};"></div>
              </div>
              <span class="bar-percent">{{ block.settings.percentage }}%</span>
            </div>
          {% endif %}
        {% endfor %}
      </div>

      <div class="feature-badges">
        {% for block in section.blocks %}
          {% if block.type == 'badge' %}
            <div class="feature-badge" {{ block.shopify_attributes }}>
              <span class="badge-icon">{{ block.settings.icon }}</span>
              <div class="badge-texts">
                <span class="badge-title">{{ block.settings.title }}</span>
                <span class="badge-sub">{{ block.settings.subtitle }}</span>
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </section>

  <svg class="impact-wave" viewBox="0 0 1440 80" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
    <path d="M0,40 C360,80 1080,0 1440,40 L1440,80 L0,80 Z" fill="#FFFFFF"></path>
  </svg>
</div>

<style>
  #ReviewHero-{{ section.id }} {
    --dark: #1A1A2E;
    --font-heading: 'Fredoka', 'Outfit', sans-serif;
    background-color: {{ section.settings.bg_color }};
    position: relative;
    overflow: hidden;
    padding-top: 100px;
    padding-bottom: 80px;
  }

  .impact-dot {
    position: absolute;
    border-radius: 50%;
    filter: blur(60px);
    opacity: 0.2;
    z-index: 1;
  }
  .impact-dot-1 { width: 300px; height: 300px; background: {{ section.settings.highlight_color }}; top: -100px; left: -100px; }
  .impact-dot-2 { width: 250px; height: 250px; background: #4A7C59; bottom: 10%; right: -100px; }

  .review-hero-inner {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 60px;
    align-items: center;
    position: relative;
    z-index: 5;
    max-width: 1300px;
    margin: 0 auto;
    padding: 0 40px;
  }

  .review-badge {
    display: inline-block;
    padding: 8px 20px;
    border-radius: 50px;
    font-weight: 800;
    font-size: 14px;
    margin-bottom: 25px;
    border: 3px solid var(--dark);
    box-shadow: 4px 4px 0px var(--dark);
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .hero-title {
    font-family: var(--font-heading);
    font-size: clamp(40px, 6vw, 75px);
    font-weight: 900;
    line-height: 1.05;
    margin-bottom: 30px;
    letter-spacing: -2px;
  }

  .hero-highlight {
    font-style: italic;
  }

  .hero-subtext {
    font-size: 20px;
    line-height: 1.6;
    max-width: 550px;
    margin-bottom: 40px;
    font-weight: 500;
  }

  .btn-primary-playful {
    display: inline-block;
    padding: 18px 40px;
    border-radius: 50px;
    font-weight: 900;
    font-size: 18px;
    color: #1A1A2E;
    text-decoration: none;
    border: 3px solid var(--dark);
    box-shadow: 6px 6px 0px var(--dark);
    transition: all 0.2s ease;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .btn-primary-playful:hover {
    transform: translate(-2px, -2px);
    box-shadow: 8px 8px 0px var(--dark);
  }

  .hero-stats-card {
    background: #FFFFFF;
    border-radius: 40px;
    padding: 40px;
    border: 4px solid var(--dark);
    box-shadow: 20px 20px 0px var(--dark);
  }

  .stats-header {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: 30px;
    padding-bottom: 25px;
    border-bottom: 2px dashed rgba(0,0,0,0.1);
  }

  .big-score {
    font-family: var(--font-heading);
    font-size: 65px;
    font-weight: 900;
    line-height: 1;
  }

  .stars {
    font-size: 24px;
    margin-bottom: 5px;
  }

  .total-revs {
    font-size: 14px;
    font-weight: 700;
    opacity: 0.7;
  }

  .rating-bars {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 35px;
  }

  .rating-bar-row {
    display: flex;
    align-items: center;
    gap: 15px;
    font-weight: 700;
    font-size: 14px;
  }

  .bar-track {
    flex: 1;
    height: 12px;
    background: #F0F0F0;
    border-radius: 10px;
    overflow: hidden;
  }

  .bar-fill {
    height: 100%;
    border-radius: 10px;
  }

  .feature-badges {
    display: grid;
    grid-template-columns: 1fr;
    gap: 15px;
  }

  .feature-badge {
    display: flex;
    align-items: center;
    gap: 15px;
    padding: 15px;
    background: #FAF7F2;
    border-radius: 20px;
    border: 2px solid var(--dark);
  }

  .badge-icon {
    font-size: 24px;
  }

  .badge-title {
    display: block;
    font-weight: 800;
    font-size: 14px;
  }

  .badge-sub {
    font-size: 12px;
    opacity: 0.8;
    font-weight: 600;
  }

  .impact-wave {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 60px;
    z-index: 2;
  }

  @media (max-width: 960px) {
    .review-hero-inner {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 50px;
    }
    .hero-subtext {
      margin-left: auto;
      margin-right: auto;
    }
    .hero-stats-card {
      max-width: 500px;
      margin: 0 auto;
    }
    #ReviewHero-{{ section.id }} {
      padding-top: 60px;
    }
  }

  .fade-up {
    animation: fadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>

{% schema %}
{
  "name": "Review Hero",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Background Color", "default": "#1C3A2F" },
    { "type": "color", "id": "text_color", "label": "Text Color", "default": "#FFFFFF" },
    { "type": "text", "id": "badge_text", "label": "Badge Text", "default": "⭐️ Rated 4.9/5 by 14K+ Parents" },
    { "type": "color", "id": "badge_bg", "label": "Badge Background", "default": "#FFEBAD" },
    { "type": "color", "id": "badge_color", "label": "Badge Text Color", "default": "#1A1A2E" },
    { "type": "text", "id": "heading_main", "label": "Heading Main", "default": "Thousands of Tails" },
    { "type": "text", "id": "heading_italic", "label": "Heading Italic", "default": "Wagging with Joy" },
    { "type": "color", "id": "highlight_color", "label": "Highlight Color", "default": "#F2C07A" },
    { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "Real reviews from real pet parents who fell in love with their personalized PawCo creations." },
    { "type": "header", "content": "Stats Card" },
    { "type": "text", "id": "score", "label": "Average Score", "default": "4.9" },
    { "type": "text", "id": "review_count_text", "label": "Review Count Text", "default": "Based on 14,280 reviews" },
    { "type": "color", "id": "star_color", "label": "Star/Fill Color", "default": "#E8A020" },
    { "type": "color", "id": "bar_track_color", "label": "Bar Track Color", "default": "rgba(255,255,255,0.12)" }
  ],
  "blocks": [
    {
      "type": "rating_bar",
      "name": "Rating Bar",
      "limit": 5,
      "settings": [
        { "type": "text", "id": "label", "label": "Label (e.g. 5★)", "default": "5★" },
        { "type": "range", "id": "percentage", "min": 0, "max": 100, "step": 1, "unit": "%", "label": "Percentage", "default": 88 }
      ]
    },
    {
      "type": "badge",
      "name": "Feature Badge",
      "limit": 3,
      "settings": [
        { "type": "text", "id": "icon", "label": "Emoji/Icon", "default": "🎨" },
        { "type": "text", "id": "title", "label": "Title", "default": "Personalization Quality" },
        { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Rated 4.9 / 5.0" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Review Hero",
      "blocks": [
        { "type": "rating_bar", "settings": { "label": "5★", "percentage": 88 } },
        { "type": "rating_bar", "settings": { "label": "4★", "percentage": 9 } },
        { "type": "rating_bar", "settings": { "label": "3★", "percentage": 2 } },
        { "type": "badge", "settings": { "icon": "🎨", "title": "Personalization Quality", "subtitle": "Rated 4.9 / 5.0" } },
        { "type": "badge", "settings": { "icon": "📦", "title": "Packaging & Delivery", "subtitle": "Rated 4.8 / 5.0" } }
      ]
    }
  ]
}
{% endschema %}
