{% comment %}
  Section: Impact Quality
  Image + Checklist with a premium badge.
{% endcomment %}

<div id="ImpactQuality-{{ section.id }}" class="impact-quality-wrapper">
  <div class="page-width">
    <div class="impact-quality-grid">
      
      <!-- Visual Side -->
      <div class="impact-quality-visual-container">
        <div class="impact-quality-card" style="background: {{ section.settings.visual_bg_gradient }};">
          {% if section.settings.main_image != blank %}
            <img src="{{ section.settings.main_image | image_url: width: 800 }}" 
                 alt="Quality"
                 class="quality-main-img"
                 loading="lazy">
          {% else %}
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg quality-main-img' }}
          {% endif %}
          
          <div class="quality-floating-badge" style="background-color: {{ section.settings.badge_bg_color }};">
            <span class="badge-num">{{ section.settings.badge_number }}</span>
            <span class="badge-text">{{ section.settings.badge_text }}</span>
          </div>
        </div>
      </div>

      <!-- Text Side -->
      <div class="impact-quality-content">
        <div class="quality-top-badge" style="background-color: {{ section.settings.top_badge_bg_color }};">
          {{ section.settings.top_badge_label }}
        </div>
        
        <h2 class="quality-heading">{{ section.settings.heading }}</h2>
        <p class="quality-subtext">{{ section.settings.subtext }}</p>

        <div class="quality-checklist">
          {% for block in section.blocks %}
            {% if block.type == 'quality_item' %}
              <div class="quality-item" {{ block.shopify_attributes }}>
                <div class="quality-check-circle" style="background-color: {{ section.settings.check_color }};">
                   <svg width="14" height="10" viewBox="0 0 14 10" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M1 5L5 9L13 1" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                   </svg>
                </div>
                <div class="quality-item-text">
                  <h4>{{ block.settings.title }}</h4>
                  <p>{{ block.settings.description }}</p>
                </div>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>

    </div>
  </div>
</div>

<style>
  #ImpactQuality-{{ section.id }} {
    --dark: #1A1A2E;
    --font-heading: 'Fredoka', 'Outfit', sans-serif;
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    padding-left: {{ section.settings.padding_left }}px;
    padding-right: {{ section.settings.padding_right }}px;
  }

  .impact-quality-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }

  /* Visual */
  .impact-quality-visual-container {
    padding: 20px;
  }

  .impact-quality-card {
    position: relative;
    aspect-ratio: 1 / 1.1;
    border: 4px solid var(--dark);
    border-radius: 40px;
    box-shadow: 15px 15px 0px var(--dark);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: visible;
  }

  .quality-main-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 36px;
    z-index: 1;
  }

  .quality-floating-badge {
    position: absolute;
    bottom: -30px;
    right: -30px;
    width: 140px;
    height: 140px;
    border-radius: 30px;
    border: 4px solid var(--dark);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    transform: rotate(5deg);
    z-index: 10;
    box-shadow: 8px 8px 0px var(--dark);
  }

  .badge-num {
    font-family: var(--font-heading);
    font-size: 38px;
    font-weight: 900;
    line-height: 1;
    color: var(--dark);
  }

  .badge-text {
    font-size: 14px;
    font-weight: 800;
    line-height: 1.1;
    color: var(--dark);
    max-width: 90px;
    text-transform: uppercase;
  }

  /* Content */
  .quality-top-badge {
    display: inline-flex;
    padding: 8px 22px;
    border-radius: 50px;
    border: 3px solid var(--dark);
    font-weight: 800;
    font-size: 16px;
    margin-bottom: 25px;
    box-shadow: 4px 4px 0px var(--dark);
  }

  .quality-heading {
    font-family: var(--font-heading);
    font-size: clamp(35px, 5vw, 60px);
    font-weight: 900;
    line-height: 1.1;
    color: var(--dark);
    margin: 0 0 20px 0;
  }

  .quality-subtext {
    font-size: 20px;
    line-height: 1.6;
    color: #444;
    font-weight: 500;
    margin-bottom: 40px;
  }

  .quality-checklist {
    display: flex;
    flex-direction: column;
    gap: 25px;
  }

  .quality-item {
    display: flex;
    gap: 20px;
    align-items: flex-start;
  }

  .quality-check-circle {
    width: 35px;
    height: 35px;
    border-radius: 50%;
    border: 3px solid var(--dark);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 5px;
    box-shadow: 3px 3px 0px var(--dark);
  }

  .quality-item-text h4 {
    font-family: var(--font-heading);
    font-size: 22px;
    font-weight: 900;
    color: var(--dark);
    margin: 0 0 5px 0;
  }

  .quality-item-text p {
    margin: 0;
    font-size: 16px;
    line-height: 1.5;
    color: #555;
    font-weight: 500;
  }

  @media (max-width: 991px) {
    .impact-quality-grid {
      grid-template-columns: 1fr;
      gap: 60px;
      text-align: center;
    }
    .impact-quality-visual-container {
      max-width: 500px;
      margin: 0 auto;
    }
    .quality-top-badge { justify-content: center; }
    .quality-item { text-align: left; }
  }
</style>

{% schema %}
{
  "name": "Impact Quality Section",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Section Background", "default": "#FDF1DF" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 160, "step": 4, "unit": "px", "label": "Padding Top", "default": 100 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 160, "step": 4, "unit": "px", "label": "Padding Bottom", "default": 100 },
    {
      "type": "range",
      "id": "padding_left",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Padding Left",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_right",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Padding Right",
      "default": 20
    },
    { "type": "header", "content": "Visual Card" },
    { "type": "color_background", "id": "visual_bg_gradient", "label": "Card Background Gradient", "default": "linear-gradient(180deg, #F2C07A 0%, #D4832A 100%)" },
    { "type": "image_picker", "id": "main_image", "label": "Main Image" },
    { "type": "text", "id": "badge_number", "label": "Floating Badge Number", "default": "100%" },
    { "type": "text", "id": "badge_text", "label": "Floating Badge Text", "default": "Vet Reviewed" },
    { "type": "color", "id": "badge_bg_color", "label": "Floating Badge Background", "default": "#1C3A2F" },
    { "type": "header", "content": "Content" },
    { "type": "text", "id": "top_badge_label", "label": "Top Badge Label", "default": "🐾 Product Responsibility" },
    { "type": "color", "id": "top_badge_bg_color", "label": "Top Badge Background", "default": "#FFEBAD" },
    { "type": "inline_richtext", "id": "heading", "label": "Heading", "default": "Only the Best Makes It to Your Pet's Bowl" },
    { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "We hold ourselves to the highest possible standards." },
    { "type": "color", "id": "check_color", "label": "Checkmark Circle Color", "default": "#4A7C59" }
  ],
  "blocks": [
    {
      "type": "quality_item",
      "name": "Quality Item",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Expert-formulated" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "Every product begins with our team of accredited pet nutritionists." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Impact Quality Section",
      "blocks": [
        { "type": "quality_item", "settings": { "title": "Expert-formulated" } },
        { "type": "quality_item", "settings": { "title": "Rigorous safety testing" } },
        { "type": "quality_item", "settings": { "title": "Transparent ingredients" } }
      ]
    }
  ]
}
{% endschema %}
