{% comment %}
  Section: Review Marquee (Playful Pet Master Style)
  Animated scrolling marquee for customer reviews with bold playful cards.
{% endcomment %}

<div id="ReviewMarquee-{{ section.id }}" class="review-marquee-wrapper">
  <div class="marquee-inner">
    {% if section.settings.label != blank %}
      <p class="marquee-label-playful">{{ section.settings.label }}</p>
    {% endif %}
    
    <div class="marquee-overflow">
      <div class="marquee-track" style="animation-duration: {{ section.settings.speed }}s;">
        {% for i in (1..3) %}
          {% for block in section.blocks %}
            <div class="marquee-card-playful" {{ block.shopify_attributes }}>
              <div class="mc-stars" style="color: {{ section.settings.star_color }};">{{ block.settings.stars }}</div>
              <div class="mc-quote" style="color: {{ section.settings.text_color }};">"{{ block.settings.quote }}"</div>
              <div class="mc-author">
                {% if block.settings.avatar != blank %}
                  <img class="mc-avatar" src="{{ block.settings.avatar | image_url: width: 80 }}" alt="{{ block.settings.author_name }}">
                {% else %}
                  <div class="mc-avatar-placeholder"></div>
                {% endif %}
                <div class="mc-info">
                  <div class="mc-name" style="color: {{ section.settings.author_color }};">{{ block.settings.author_name }}</div>
                  <div class="mc-product" style="color: {{ section.settings.product_color }};">{{ block.settings.product_name }}</div>
                </div>
              </div>
            </div>
          {% endfor %}
        {% endfor %}
      </div>
    </div>
  </div>
</div>

<style>
  #ReviewMarquee-{{ section.id }} {
    --dark: #1A1A2E;
    --font-heading: 'Fredoka', 'Outfit', sans-serif;
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    padding-left: {{ section.settings.padding_left }}px;
    padding-right: {{ section.settings.padding_right }}px;
    overflow: hidden;
  }

  .marquee-label-playful {
    text-align: center;
    font-size: 14px;
    font-weight: 800;
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 40px;
    color: var(--dark);
    opacity: 0.8;
  }

  .marquee-overflow {
    overflow: hidden;
    width: 100%;
    padding: 20px 0;
  }

  .marquee-track {
    display: flex;
    gap: 30px;
    animation: marquee linear infinite;
    width: max-content;
  }

  .marquee-track:hover {
    animation-play-state: paused;
  }

  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-33.33%); }
  }

  .marquee-card-playful {
    border-radius: 30px;
    border: 3px solid var(--dark);
    padding: 25px;
    width: 340px;
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    background: #fff;
    box-shadow: 8px 8px 0px var(--dark);
    transition: transform 0.3s ease;
  }

  .marquee-card-playful:hover {
    transform: translateY(-5px);
  }

  .mc-stars {
    font-size: 16px;
    margin-bottom: 15px;
    letter-spacing: 1px;
  }

  .mc-quote {
    font-size: 16px;
    line-height: 1.5;
    font-weight: 600;
    font-style: italic;
    margin-bottom: 20px;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .mc-author {
    display: flex;
    align-items: center;
    gap: 15px;
    margin-top: auto;
    padding-top: 15px;
    border-top: 2px dashed rgba(0,0,0,0.1);
  }

  .mc-avatar {
    width: 45px;
    height: 45px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--dark);
  }

  .mc-avatar-placeholder {
    width: 45px;
    height: 45px;
    border-radius: 50%;
    border: 2px solid var(--dark);
    background-color: #eee;
  }

  .mc-info {
    flex: 1;
  }

  .mc-name {
    font-family: var(--font-heading);
    font-size: 15px;
    font-weight: 900;
  }

  .mc-product {
    font-size: 12px;
    font-weight: 700;
    opacity: 0.7;
  }
</style>

{% schema %}
{
  "name": "Review Marquee",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Background Color", "default": "#FAF7F2" },
    { "type": "text", "id": "label", "label": "Marquee Label", "default": "What pet parents are saying right now" },
    { "type": "range", "id": "speed", "min": 10, "max": 100, "step": 5, "unit": "s", "label": "Animation Speed", "default": 40 },
    { "type": "header", "content": "Card Styling" },
    { "type": "color", "id": "text_color", "label": "Quote Color", "default": "#1A1A2E" },
    { "type": "color", "id": "author_color", "label": "Author Color", "default": "#1A1A2E" },
    { "type": "color", "id": "product_color", "label": "Product Color", "default": "#4A7C59" },
    { "type": "color", "id": "star_color", "label": "Star Color", "default": "#E8A020" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 5, "unit": "px", "label": "Padding Top", "default": 80 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 5, "unit": "px", "label": "Padding Bottom", "default": 40 },
    { "type": "header", "content": "Section Padding" },
    { "type": "range", "id": "padding_left", "min": 0, "max": 100, "step": 5, "unit": "px", "label": "Padding Left", "default": 0 },
    { "type": "range", "id": "padding_right", "min": 0, "max": 100, "step": 5, "unit": "px", "label": "Padding Right", "default": 0 }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review Card",
      "settings": [
        { "type": "text", "id": "stars", "label": "Stars Text", "default": "★★★★★" },
        { "type": "textarea", "id": "quote", "label": "Quote", "default": "The custom portrait of my golden retriever Biscuit arrived and I literally cried." },
        { "type": "image_picker", "id": "avatar", "label": "Author Avatar" },
        { "type": "text", "id": "author_name", "label": "Author Name", "default": "Sarah M." },
        { "type": "text", "id": "product_name", "label": "Product Name", "default": "Custom Pet Portrait" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Review Marquee",
      "blocks": [
        { "type": "review", "settings": { "author_name": "Sarah M.", "product_name": "Custom Pet Portrait" } },
        { "type": "review", "settings": { "author_name": "James T.", "product_name": "Personalized Blanket" } },
        { "type": "review", "settings": { "author_name": "Priya K.", "product_name": "Engraved ID Tag" } }
      ]
    }
  ]
}
{% endschema %}
