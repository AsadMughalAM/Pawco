{% comment %}
  Section: Review Trust Strip (Playful Pet Master Style)
  Counter/stats strip for social proof with bold playful typography.
{% endcomment %}

<div id="ReviewTrust-{{ section.id }}" class="review-trust-wrapper">
  <section class="trust-strip">
    <div class="trust-inner">
      {% for block in section.blocks %}
        <div class="trust-item-playful" {{ block.shopify_attributes }}>
          <div class="trust-num" style="color: {{ section.settings.number_color }};">
            {{ block.settings.number }}<span class="suffix" style="color: {{ section.settings.accent_color }};">{{ block.settings.suffix }}</span>
          </div>
          <div class="trust-lbl" style="color: {{ section.settings.label_color }};">
            {{ block.settings.label }}
          </div>
        </div>
      {% endfor %}
    </div>
  </section>
</div>

<style>
  #ReviewTrust-{{ section.id }} {
    --dark: #1A1A2E;
    --font-heading: 'Fredoka', 'Outfit', sans-serif;
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    padding-left: {{ section.settings.padding_left }}px;
    padding-right: {{ section.settings.padding_right }}px;
    position: relative;
    overflow: hidden;
  }

  .trust-inner {
    max-width: 1300px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 40px;
    padding: 0 40px;
  }

  .trust-item-playful {
    text-align: center;
    padding: 30px 20px;
    background: rgba(255,255,255,0.05);
    border-radius: 30px;
    border: 2px solid rgba(255,255,255,0.1);
    transition: transform 0.3s ease;
  }

  .trust-item-playful:hover {
    transform: translateY(-5px);
    background: rgba(255,255,255,0.08);
  }

  .trust-num {
    font-family: var(--font-heading);
    font-size: clamp(36px, 4.5vw, 60px);
    font-weight: 900;
    line-height: 1;
    margin-bottom: 10px;
    letter-spacing: -1.5px;
  }

  .trust-num .suffix {
    font-style: italic;
  }

  .trust-lbl {
    font-size: 14px;
    line-height: 1.5;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 1px;
    opacity: 0.8;
  }

  @media (max-width: 960px) {
    .trust-inner {
      grid-template-columns: repeat(2, 1fr);
      gap: 25px;
    }
  }

  @media (max-width: 550px) {
    .trust-inner {
      grid-template-columns: 1fr;
    }
  }
</style>

{% schema %}
{
  "name": "Review Trust Strip",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Background Color", "default": "#1C3A2F" },
    { "type": "color", "id": "number_color", "label": "Number Color", "default": "#FFFFFF" },
    { "type": "color", "id": "accent_color", "label": "Accent Color", "default": "#F2C07A" },
    { "type": "color", "id": "label_color", "label": "Label Color", "default": "#FFFFFF" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 5, "unit": "px", "label": "Padding Top", "default": 80 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 5, "unit": "px", "label": "Padding Bottom", "default": 80 },
    { "type": "header", "content": "Section Padding" },
    { "type": "range", "id": "padding_left", "min": 0, "max": 100, "step": 5, "unit": "px", "label": "Padding Left", "default": 40 },
    { "type": "range", "id": "padding_right", "min": 0, "max": 100, "step": 5, "unit": "px", "label": "Padding Right", "default": 40 }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat Item",
      "limit": 4,
      "settings": [
        { "type": "text", "id": "number", "label": "Number", "default": "14" },
        { "type": "text", "id": "suffix", "label": "Suffix", "default": "K+" },
        { "type": "textarea", "id": "label", "label": "Label", "default": "Verified Reviews" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Review Trust Strip",
      "blocks": [
        { "type": "stat", "settings": { "number": "14", "suffix": "K+", "label": "Verified Reviews" } },
        { "type": "stat", "settings": { "number": "4", "suffix": ".9★", "label": "Average Rating" } },
        { "type": "stat", "settings": { "number": "98", "suffix": "%", "label": "Happy Parents" } },
        { "type": "stat", "settings": { "number": "50", "suffix": "K+", "label": "Pets Served" } }
      ]
    }
  ]
}
{% endschema %}
