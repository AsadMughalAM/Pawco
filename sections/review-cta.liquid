{% comment %}
  Section: Review CTA (Playful Pet Master Style)
  Call to action for writing a review or shopping with bold playful styles.
{% endcomment %}

<div id="ReviewCTA-{{ section.id }}" class="review-cta-wrapper">
  <section class="review-cta">
    <div class="section-inner">
      <span class="section-tag-playful" style="background-color: {{ section.settings.tag_color }}; color: #fff;">{{ section.settings.tag }}</span>
      <h2 class="section-title" style="color: {{ section.settings.heading_color }};">{{ section.settings.heading }}</h2>
      <p class="section-sub" style="color: {{ section.settings.subtext_color }};">{{ section.settings.subtext }}</p>
      
      <div class="cta-btns">
        {% if section.settings.btn1_label != blank %}
          <a href="{{ section.settings.btn1_url }}" class="btn-playful primary" 
             style="background-color: {{ section.settings.btn1_bg }}; color: {{ section.settings.btn1_text }};">
            {{ section.settings.btn1_label }}
          </a>
        {% endif %}
        {% if section.settings.btn2_label != blank %}
          <a href="{{ section.settings.btn2_url }}" class="btn-playful outline" 
             style="background-color: #fff; color: {{ section.settings.btn2_text }};">
            {{ section.settings.btn2_label }}
          </a>
        {% endif %}
      </div>
    </div>
  </section>
</div>

<style>
  #ReviewCTA-{{ section.id }} {
    --dark: #1A1A2E;
    --font-heading: 'Fredoka', 'Outfit', sans-serif;
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    padding-left: {{ section.settings.padding_left }}px;
    padding-right: {{ section.settings.padding_right }}px;
    position: relative;
    overflow: hidden;
  }

  .review-cta {
    text-align: center;
    position: relative;
    z-index: 5;
  }

  .section-tag-playful {
    display: inline-block;
    padding: 6px 15px;
    border-radius: 50px;
    font-weight: 800;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 20px;
    border: 2px solid var(--dark);
    box-shadow: 3px 3px 0px var(--dark);
  }

  .section-title {
    font-family: var(--font-heading);
    font-size: clamp(32px, 5vw, 55px);
    font-weight: 900;
    line-height: 1.1;
    margin: 0 auto 20px;
    max-width: 800px;
    letter-spacing: -1.5px;
  }

  .section-sub {
    font-size: 20px;
    line-height: 1.6;
    max-width: 600px;
    margin: 0 auto 50px;
    font-weight: 500;
    opacity: 0.8;
  }

  .cta-btns {
    display: flex;
    gap: 24px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn-playful {
    padding: 18px 40px;
    border-radius: 50px;
    text-decoration: none;
    font-size: 16px;
    font-weight: 900;
    transition: all 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    display: inline-block;
    border: 3px solid var(--dark);
    box-shadow: 6px 6px 0px var(--dark);
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .btn-playful:hover {
    transform: translate(-3px, -3px);
    box-shadow: 10px 10px 0px var(--dark);
  }

  .btn-playful.primary {
    /* bg set in inline style */
  }

  .btn-playful.outline {
    /* bg white set in inline style */
  }

  @media (max-width: 768px) {
    .section-title {
      font-size: 32px;
    }
    .btn-playful {
      width: 100%;
      max-width: 350px;
    }
  }
</style>

{% schema %}
{
  "name": "Review CTA",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Background Color", "default": "#FAF7F2" },
    { "type": "text", "id": "tag", "label": "Tag", "default": "Share Your Story" },
    { "type": "color", "id": "tag_color", "label": "Tag Color", "default": "#4A7C59" },
    { "type": "text", "id": "heading", "label": "Loved Your PawCo Order? Tell the World." },
    { "type": "color", "id": "heading_color", "label": "Heading Color", "default": "#1A1A2E" },
    { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "Your review helps other pet parents find the perfect personalized gift. Join the family!" },
    { "type": "color", "id": "subtext_color", "label": "Subtext Color", "default": "#4A4A4A" },
    { "type": "header", "content": "Button 1" },
    { "type": "text", "id": "btn1_label", "label": "Label", "default": "Write a Review" },
    { "type": "url", "id": "btn1_url", "label": "URL" },
    { "type": "color", "id": "btn1_bg", "label": "Background", "default": "#F2C07A" },
    { "type": "color", "id": "btn1_text", "label": "Text", "default": "#1A1A2E" },
    { "type": "header", "content": "Button 2" },
    { "type": "text", "id": "btn2_label", "label": "Label", "default": "Shop Personalized Gifts" },
    { "type": "url", "id": "btn2_url", "label": "URL" },
    { "type": "color", "id": "btn2_text", "label": "Text Color", "default": "#1A1A2E" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 5, "unit": "px", "label": "Padding Top", "default": 100 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 5, "unit": "px", "label": "Padding Bottom", "default": 100 },
    { "type": "header", "content": "Section Padding" },
    { "type": "range", "id": "padding_left", "min": 0, "max": 100, "step": 5, "unit": "px", "label": "Padding Left", "default": 40 },
    { "type": "range", "id": "padding_right", "min": 0, "max": 100, "step": 5, "unit": "px", "label": "Padding Right", "default": 40 }
  ],
  "presets": [
    {
      "name": "Review CTA"
    }
  ]
}
{% endschema %}
