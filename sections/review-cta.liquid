{% comment %}
  Section: Review CTA
  Call to action for writing a review or shopping.
{% endcomment %}

<div id="ReviewCTA-{{ section.id }}" class="review-cta-wrapper">
  <section class="review-cta">
    <div class="section-inner">
      <span class="section-tag" style="color: {{ section.settings.tag_color }};">{{ section.settings.tag }}</span>
      <h2 class="section-title" style="color: {{ section.settings.heading_color }};">{{ section.settings.heading }}</h2>
      <p class="section-sub" style="color: {{ section.settings.subtext_color }};">{{ section.settings.subtext }}</p>
      
      <div class="cta-btns">
        {% if section.settings.btn1_label != blank %}
          <a href="{{ section.settings.btn1_url }}" class="btn-primary" 
             style="background-color: {{ section.settings.btn1_bg }}; color: {{ section.settings.btn1_text }};">
            {{ section.settings.btn1_label }}
          </a>
        {% endif %}
        {% if section.settings.btn2_label != blank %}
          <a href="{{ section.settings.btn2_url }}" class="btn-outline" 
             style="border-color: {{ section.settings.btn2_border }}; color: {{ section.settings.btn2_text }};">
            {{ section.settings.btn2_label }}
          </a>
        {% endif %}
      </div>
    </div>
  </section>
</div>

<style>
  #ReviewCTA-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .review-cta {
    text-align: center;
  }

  .section-tag {
    display: inline-block;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 12px;
  }

  .section-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(28px, 4vw, 42px);
    font-weight: 600;
    line-height: 1.2;
    margin: 0 auto 15px;
    max-width: 600px;
  }

  .section-sub {
    font-size: 18px;
    line-height: 1.6;
    max-width: 600px;
    margin: 0 auto 40px;
    font-weight: 300;
  }

  .cta-btns {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn-primary {
    padding: 14px 32px;
    border-radius: 50px;
    text-decoration: none;
    font-size: 15px;
    font-weight: 600;
    transition: transform 0.2s;
    display: inline-block;
    border: none;
  }

  .btn-primary:hover {
    transform: translateY(-3px);
    opacity: 0.9;
  }

  .btn-outline {
    padding: 12px 32px;
    border-radius: 50px;
    text-decoration: none;
    font-size: 15px;
    font-weight: 600;
    transition: all 0.2s;
    display: inline-block;
    border: 2px solid;
    background: transparent;
  }

  .btn-outline:hover {
    transform: translateY(-3px);
    opacity: 0.8;
  }
</style>

{% schema %}
{
  "name": "Review CTA",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Background Color", "default": "#FFFFFF" },
    { "type": "text", "id": "tag", "label": "Tag", "default": "Share Your Story" },
    { "type": "color", "id": "tag_color", "label": "Tag Color", "default": "#4A7C59" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Loved Your PawCo Order? Tell the World." },
    { "type": "color", "id": "heading_color", "label": "Heading Color", "default": "#1A1A1A" },
    { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "Your review helps other pet parents find the perfect personalized gift." },
    { "type": "color", "id": "subtext_color", "label": "Subtext Color", "default": "#4A4A4A" },
    { "type": "header", "content": "Button 1" },
    { "type": "text", "id": "btn1_label", "label": "Label", "default": "Write a Review" },
    { "type": "url", "id": "btn1_url", "label": "URL" },
    { "type": "color", "id": "btn1_bg", "label": "Background", "default": "#1C3A2F" },
    { "type": "color", "id": "btn1_text", "label": "Text", "default": "#FFFFFF" },
    { "type": "header", "content": "Button 2" },
    { "type": "text", "id": "btn2_label", "label": "Label", "default": "Shop Personalized Gifts" },
    { "type": "url", "id": "btn2_url", "label": "URL" },
    { "type": "color", "id": "btn2_border", "label": "Border", "default": "#1C3A2F" },
    { "type": "color", "id": "btn2_text", "label": "Text", "default": "#1C3A2F" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 5, "unit": "px", "label": "Padding Top", "default": 100 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 5, "unit": "px", "label": "Padding Bottom", "default": 100 }
  ],
  "presets": [
    {
      "name": "Review CTA"
    }
  ]
}
{% endschema %}
