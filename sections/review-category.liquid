{% comment %}
  Section: Review Category
  Tabbed category reviews showing product specific feedback.
{% endcomment %}

<div id="ReviewCategory-{{ section.id }}" class="review-category-wrapper">
  <section class="section-inner">
    <div class="header-content" style="text-align: {{ section.settings.header_align }};">
      <span class="section-tag" style="color: {{ section.settings.tag_color }};">{{ section.settings.tag }}</span>
      <h2 class="section-title" style="color: {{ section.settings.heading_color }};">{{ section.settings.heading }}</h2>
      <p class="section-sub" style="color: {{ section.settings.subtext_color }};">{{ section.settings.subtext }}</p>
    </div>

    <div class="cat-tabs">
      {% for block in section.blocks %}
        {% if block.type == 'category' %}
          <button class="cat-tab {% if forloop.first %}active{% endif %}" 
                  data-tab="tab-{{ block.id }}"
                  style="--tab-border: {{ section.settings.card_border }}; --tab-active-bg: {{ section.settings.heading_bg }};">
            {{ block.settings.title }}
          </button>
        {% endif %}
      {% endfor %}
    </div>

    <div class="cat-contents">
      {% for block in section.blocks %}
        {% if block.type == 'category' %}
          <div id="tab-{{ block.id }}" class="cat-content {% if forloop.first %}active{% endif %}">
            <div class="cat-product-panel" style="background-color: {{ section.settings.card_bg }}; border-color: {{ section.settings.card_border }};">
              {% if block.settings.image != blank %}
                <img class="cpp-img" src="{{ block.settings.image | image_url: width: 800 }}" alt="{{ block.settings.title }}">
              {% else %}
                <div class="cpp-img-placeholder"></div>
              {% endif %}
              <div class="cpp-body">
                <div class="cpp-title" style="color: {{ section.settings.heading_bg }};">{{ block.settings.title }}</div>
                <div class="cpp-rating">
                  <span class="cpp-stars" style="color: {{ section.settings.star_color }};">{{ block.settings.stars }}</span>
                  <span class="cpp-num" style="color: {{ section.settings.subtext_color }}; opacity: 0.7;">{{ block.settings.rating_text }}</span>
                </div>
                <div class="cpp-review-list">
                  {% if block.settings.rev1_name != blank %}
                    <div class="mini-review" style="background-color: {{ section.settings.mini_rev_bg }};">
                      <div class="mr-head"><span class="mr-name" style="color: {{ section.settings.heading_color }};">{{ block.settings.rev1_name }}</span><span class="mr-stars" style="color: {{ section.settings.star_color }};">{{ block.settings.rev1_stars }}</span></div>
                      <p class="mr-quote" style="color: {{ section.settings.subtext_color }};">"{{ block.settings.rev1_quote }}"</p>
                    </div>
                  {% endif %}
                  {% if block.settings.rev2_name != blank %}
                    <div class="mini-review" style="background-color: {{ section.settings.mini_rev_bg }};">
                      <div class="mr-head"><span class="mr-name" style="color: {{ section.settings.heading_color }};">{{ block.settings.rev2_name }}</span><span class="mr-stars" style="color: {{ section.settings.star_color }};">{{ block.settings.rev2_stars }}</span></div>
                      <p class="mr-quote" style="color: {{ section.settings.subtext_color }};">"{{ block.settings.rev2_quote }}"</p>
                    </div>
                  {% endif %}
                </div>
              </div>
            </div>

            <div class="cat-summary">
              {% for subblock in section.blocks %}
                {% if subblock.type == 'summary_item' %}
                  <div class="summary-card" style="background-color: {{ section.settings.card_bg }}; border-color: {{ section.settings.card_border }};">
                    <div class="summary-icon" style="background-color: {{ section.settings.icon_bg }};">{{ subblock.settings.icon }}</div>
                    <div class="summary-text">
                      <h4 style="color: {{ section.settings.heading_bg }};">{{ subblock.settings.title }}</h4>
                      <p style="color: {{ section.settings.subtext_color }}; opacity: 0.8;">{{ subblock.settings.description }}</p>
                    </div>
                    <div class="summary-score">
                      <div class="s-num" style="color: {{ section.settings.heading_bg }};">{{ subblock.settings.score }}</div>
                      <div class="s-stars" style="color: {{ section.settings.star_color }};">{{ subblock.settings.stars }}</div>
                    </div>
                  </div>
                {% endif %}
              {% endfor %}
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </section>
</div>

<style>
  #ReviewCategory-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .cat-tabs {
    display: flex;
    gap: 10px;
    margin: 30px 0 40px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .cat-tab {
    padding: 8px 24px;
    border-radius: 50px;
    border: 1.5px solid var(--tab-border);
    font-size: 14px;
    font-weight: 500;
    color: #4A4A4A;
    cursor: pointer;
    transition: all 0.2s;
    background: white;
  }

  .cat-tab.active {
    background: var(--tab-active-bg);
    color: white;
    border-color: var(--tab-active-bg);
  }

  .cat-content {
    display: none;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
  }

  .cat-content.active {
    display: grid;
  }

  .cat-product-panel {
    border-radius: 24px;
    border: 1px solid;
    overflow: hidden;
  }

  .cpp-img, .cpp-img-placeholder {
    width: 100%;
    height: 300px;
    object-fit: cover;
    display: block;
    background-color: #eee;
  }

  .cpp-body {
    padding: 30px;
  }

  .cpp-title {
    font-family: 'Playfair Display', serif;
    font-size: 24px;
    font-weight: 600;
    margin-bottom: 8px;
  }

  .cpp-rating {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 24px;
  }

  .cpp-stars {
    font-size: 16px;
  }

  .cpp-num {
    font-size: 14px;
  }

  .cpp-review-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .mini-review {
    padding: 20px;
    border-radius: 16px;
  }

  .mr-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 8px;
  }

  .mr-name {
    font-size: 14px;
    font-weight: 600;
  }

  .mr-stars {
    font-size: 12px;
  }

  .mr-quote {
    font-size: 14px;
    line-height: 1.6;
    font-style: italic;
  }

  .cat-summary {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .summary-card {
    border-radius: 20px;
    border: 1px solid;
    padding: 24px;
    display: flex;
    align-items: flex-start;
    gap: 20px;
  }

  .summary-icon {
    width: 50px;
    height: 50px;
    flex-shrink: 0;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
  }

  .summary-text h4 {
    font-weight: 600;
    font-size: 16px;
    margin-bottom: 6px;
  }

  .summary-text p {
    font-size: 14px;
    line-height: 1.6;
    font-weight: 300;
  }

  .summary-score {
    margin-left: auto;
    flex-shrink: 0;
    text-align: right;
  }

  .summary-score .s-num {
    font-family: 'Playfair Display', serif;
    font-size: 24px;
    font-weight: 700;
    line-height: 1;
    margin-bottom: 4px;
  }

  .summary-score .s-stars {
    font-size: 12px;
  }

  @media (max-width: 960px) {
    .cat-content {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const section = document.querySelector('#ReviewCategory-{{ section.id }}');
    if (!section) return;

    const tabs = section.querySelectorAll('.cat-tab');
    const contents = section.querySelectorAll('.cat-content');

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const target = tab.getAttribute('data-tab');

        tabs.forEach(t => t.classList.remove('active'));
        contents.forEach(c => c.classList.remove('active'));

        tab.classList.add('active');
        section.querySelector('#' + target).classList.add('active');
      });
    });
  });
</script>

{% schema %}
{
  "name": "Review Categories",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Background Color", "default": "#FAF7F2" },
    { "type": "text", "id": "tag", "label": "Tag", "default": "By Product" },
    { "type": "color", "id": "tag_color", "label": "Tag Color", "default": "#4A7C59" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Reviews Across Every Category" },
    { "type": "color", "id": "heading_color", "label": "Heading Color", "default": "#1A1A1A" },
    { "type": "color", "id": "heading_bg", "label": "Accent Color", "default": "#1C3A2F" },
    { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "Personalized for every pet, loved by every owner." },
    { "type": "color", "id": "subtext_color", "label": "Subtext Color", "default": "#4A4A4A" },
    { "type": "select", "id": "header_align", "label": "Header Alignment", "options": [
      { "value": "left", "label": "Left" },
      { "value": "center", "label": "Center" }
    ], "default": "center" },
    { "type": "header", "content": "Styling" },
    { "type": "color", "id": "card_bg", "label": "Card BG", "default": "#FFFFFF" },
    { "type": "color", "id": "card_border", "label": "Card Border", "default": "rgba(74,124,89,0.15)" },
    { "type": "color", "id": "mini_rev_bg", "label": "Mini Review BG", "default": "#FAF7F2" },
    { "type": "color", "id": "icon_bg", "label": "Icon BG", "default": "#D4E8D0" },
    { "type": "color", "id": "star_color", "label": "Star Color", "default": "#E8A020" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 5, "unit": "px", "label": "Padding Top", "default": 80 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 5, "unit": "px", "label": "Padding Bottom", "default": 80 }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category Tab",
      "settings": [
        { "type": "text", "id": "title", "label": "Category Title", "default": "Custom Portraits" },
        { "type": "image_picker", "id": "image", "label": "Category Image" },
        { "type": "text", "id": "stars", "label": "Stars Text", "default": "★★★★★" },
        { "type": "text", "id": "rating_text", "label": "Rating Meta", "default": "4.9 · 5,210 reviews" },
        { "type": "header", "content": "Review 1" },
        { "type": "text", "id": "rev1_name", "label": "Reviewer 1 Name", "default": "Hannah F." },
        { "type": "text", "id": "rev1_stars", "label": "Reviewer 1 Stars", "default": "★★★★★" },
        { "type": "textarea", "id": "rev1_quote", "label": "Reviewer 1 Quote", "default": "Jaw-dropping likeness of my border collie." },
        { "type": "header", "content": "Review 2" },
        { "type": "text", "id": "rev2_name", "label": "Reviewer 2 Name", "default": "Tom K." },
        { "type": "text", "id": "rev2_stars", "label": "Reviewer 2 Stars", "default": "★★★★★" },
        { "type": "textarea", "id": "rev2_quote", "label": "Reviewer 2 Quote", "default": "Ordered a memorial portrait after losing my cat." }
      ]
    },
    {
      "type": "summary_item",
      "name": "Summary Detail",
      "limit": 4,
      "settings": [
        { "type": "text", "id": "icon", "label": "Emoji Icon", "default": "🎨" },
        { "type": "text", "id": "title", "label": "Detail Title", "default": "Personalization Accuracy" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "Customers consistently rate the likeness and detail as better than expected." },
        { "type": "text", "id": "score", "label": "Score", "default": "4.9" },
        { "type": "text", "id": "stars", "label": "Stars", "default": "★★★★★" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Review Categories",
      "blocks": [
        { "type": "category", "settings": { "title": "Custom Portraits" } },
        { "type": "category", "settings": { "title": "Blankets" } },
        { "type": "summary_item", "settings": { "icon": "🎨", "title": "Accuracy" } },
        { "type": "summary_item", "settings": { "icon": "📐", "title": "Quality" } }
      ]
    }
  ]
}
{% endschema %}
