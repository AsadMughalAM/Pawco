{% comment %}
  Section: Home Welcome & Impact Bar
  Inspired by Alpha Paw design. 50/50 text/image split with a 3-column trust bar below.
{% endcomment %}

<div id="WelcomeImpact-{{ section.id }}" class="welcome-impact-section">
  <div class="container-custom" style="max-width: {{ section.settings.content_width }}px; padding-left: {{ section.settings.padding_left }}px; padding-right: {{ section.settings.padding_right }}px;">
    
    <!-- Top Part: Text & Image Split -->
    <div class="welcome-flex">
      <div class="welcome-text-part" style="text-align: {{ section.settings.text_alignment }}; justify-content: {% if section.settings.text_alignment == 'center' %}center{% elsif section.settings.text_alignment == 'right' %}flex-end{% else %}flex-start{% endif %};">
        <div class="text-content-inner" style="margin: {% if section.settings.text_alignment == 'center' %}0 auto{% elsif section.settings.text_alignment == 'right' %}0 0 0 auto{% else %}0{% endif %};">
          <h2 class="welcome-heading" style="color: {{ section.settings.text_color }};">
            {{ section.settings.heading }}
          </h2>
          <div class="welcome-description" style="color: {{ section.settings.text_color }};">
            {{ section.settings.description }}
          </div>
          {% if section.settings.tagline != blank %}
            <p class="welcome-tagline" style="color: {{ section.settings.text_color }};">
              {{ section.settings.tagline }}
            </p>
          {% endif %}
        </div>
      </div>
      
      <div class="welcome-image-part">
        {% if section.settings.image != blank %}
          <img src="{{ section.settings.image | image_url: width: 1000 }}" alt="{{ section.settings.heading }}">
        {% else %}
          <div class="image-placeholder"></div>
        {% endif %}
      </div>
    </div>

    <!-- Bottom Part: Trust Bar -->
    <div class="trust-bar-flex">
      {% for block in section.blocks %}
        <div class="trust-item" {{ block.shopify_attributes }}>
          <div class="trust-icon">
            {% if block.settings.icon != blank %}
              <img src="{{ block.settings.icon | image_url: width: 100 }}" alt="{{ block.settings.title }}">
            {% else %}
              <div class="icon-placeholder-circle"></div>
            {% endif %}
          </div>
          <div class="trust-text">
            <h3 class="trust-title" style="color: {{ section.settings.text_color }};">{{ block.settings.title }}</h3>
            <p class="trust-desc" style="color: {{ section.settings.text_color }};">{{ block.settings.text }}</p>
          </div>
        </div>
      {% endfor %}
    </div>

  </div>
</div>

<style>
  .welcome-impact-section {
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .container-custom {
    margin: 0 auto;
    width: 100%;
  }

  /* Welcome Part Styles */
  .welcome-flex {
    display: flex;
    align-items: stretch;
    gap: 0;
    background: #fff;
    border-radius: 20px;
    overflow: hidden;
    margin-bottom: 60px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
  }

  .welcome-text-part {
    flex: 1;
    display: flex;
    align-items: center;
    padding: 60px;
    background-color: #F8F9FB;
  }

  .text-content-inner {
    max-width: 450px;
  }

  .welcome-heading {
    font-family: 'Fredoka', sans-serif;
    font-size: 32px;
    font-weight: 800;
    text-transform: uppercase;
    margin-bottom: 25px;
    line-height: 1.2;
    letter-spacing: 0.5px;
  }

  .welcome-description {
    font-size: 16px;
    line-height: 1.6;
    margin-bottom: 25px;
    opacity: 0.9;
  }

  .welcome-tagline {
    font-weight: 800;
    font-size: 18px;
    margin-top: 10px;
  }

  .welcome-image-part {
    flex: 1;
  }

  .welcome-image-part img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .image-placeholder {
    width: 100%;
    height: 100%;
    min-height: 400px;
    background-color: #eee;
  }

  /* Trust Bar Styles */
  .trust-bar-flex {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 25px;
    margin-top: 40px;
  }

  .trust-item {
    text-align: center;
    padding: 40px 25px;
    background: #ffffff;
    border-radius: 12px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.06);
    display: flex;
    flex-direction: column;
    align-items: center;
    transition: transform 0.2s ease;
  }

  .trust-item:hover {
    transform: translateY(-5px);
  }

  .trust-icon {
    margin-bottom: 20px;
    height: 50px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .trust-icon img {
    width: 45px;
    height: 45px;
    object-fit: contain;
  }

  .trust-title {
    font-family: 'Fredoka', sans-serif;
    font-size: 16px;
    font-weight: 800;
    text-transform: uppercase;
    margin-bottom: 12px;
    letter-spacing: 1px;
    color: #1a243e;
  }

  .trust-desc {
    font-size: 13px;
    line-height: 1.5;
    margin: 0;
    color: #1a243e;
    opacity: 0.8;
    max-width: 250px;
  }

  .icon-placeholder-circle {
    width: 50px;
    height: 50px;
    background: #eee;
    border-radius: 50%;
  }

  @media screen and (max-width: 991px) {
    .welcome-flex {
      flex-direction: column;
    }
    .welcome-text-part {
      padding: 40px 30px;
      order: 2;
    }
    .welcome-image-part {
      order: 1;
    }
    .trust-bar-flex {
      grid-template-columns: 1fr;
      gap: 20px;
    }
  }
</style>

{% schema %}
{
  "name": "Welcome & Trust Bar",
  "settings": [
    {
      "type": "header",
      "content": "Layout & Alignment"
    },
    {
      "type": "range",
      "id": "content_width",
      "label": "Content Max Width",
      "min": 800,
      "max": 1400,
      "step": 20,
      "unit": "px",
      "default": 1200
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Section Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#1a243e"
    },
    {
      "type": "header",
      "content": "Welcome Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "WELCOME TO THE PACK!"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "At Pawco, we believe our pets are part of the family, and family deserves the best. That's why we're committed to helping pet parents like you give your pup everything they need to live happier, healthier, and longer lives."
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "Now that's something to bark about."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Side Image"
    },
    {
      "type": "header",
      "content": "Section Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_left",
      "label": "Padding Left (Horizontal)",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_right",
      "label": "Padding Right (Horizontal)",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 20
    }
  ],
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust Item",
      "limit": 3,
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Fast Shipping"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "Most orders ship within 48 hours, Monday thru Friday."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Home Welcome & Trust Bar",
      "blocks": [
        { "type": "trust_item", "settings": { "title": "FAST SHIPPING", "text": "Most orders ship within 48 hours, Monday thru Friday." } },
        { "type": "trust_item", "settings": { "title": "HAPPINESS GUARANTEE", "text": "If you're not 100% satisfied, we proudly offer returns within 30 days." } },
        { "type": "trust_item", "settings": { "title": "OUTSTANDING SERVICE", "text": "Email or chat with our devoted customer service reps anytime." } }
      ]
    }
  ]
}
{% endschema %}
