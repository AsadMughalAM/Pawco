{% comment %}
  Section: Review Spotlight
  Featured review with a large image and big quote.
{% endcomment %}

<div id="ReviewSpotlight-{{ section.id }}" class="review-spotlight-wrapper">
  <section class="spotlight">
    <div class="spotlight-inner">
      <div class="spotlight-img-wrap">
        {% if section.settings.image != blank %}
          <img class="spotlight-img" src="{{ section.settings.image | image_url: width: 1000 }}" alt="{{ section.settings.heading }}">
        {% else %}
          <div class="spotlight-img-placeholder"></div>
        {% endif %}
        {% if section.settings.badge_text != blank %}
          <div class="spotlight-product-badge" style="background-color: {{ section.settings.badge_bg }}; color: {{ section.settings.badge_color }};">
            {{ section.settings.badge_text }}
          </div>
        {% endif %}
      </div>
      <div class="spotlight-text">
        <span class="section-tag" style="color: {{ section.settings.tag_color }};">{{ section.settings.tag }}</span>
        <h2 class="section-title" style="color: {{ section.settings.heading_color }};">{{ section.settings.heading }}</h2>
        <div class="spotlight-stars" style="color: {{ section.settings.star_color }};">{{ section.settings.stars }}</div>
        <blockquote class="big-quote" style="color: {{ section.settings.quote_color }}; border-left-color: {{ section.settings.tag_color }};">
          "{{ section.settings.quote }}"
        </blockquote>
        <div class="spotlight-reviewer">
          {% if section.settings.avatar != blank %}
            <img class="spotlight-avatar" src="{{ section.settings.avatar | image_url: width: 120 }}" alt="{{ section.settings.author }}">
          {% else %}
            <div class="spotlight-avatar-placeholder"></div>
          {% endif %}
          <div class="spotlight-reviewer-info">
            <div class="name" style="color: {{ section.settings.heading_color }};">{{ section.settings.author }}</div>
            <div class="meta" style="color: {{ section.settings.quote_color }}; opacity: 0.6;">{{ section.settings.meta }}</div>
          </div>
        </div>
        {% if section.settings.product_tag != blank %}
          <div class="spotlight-product-tag" style="background-color: {{ section.settings.tag_bg }}; border-color: {{ section.settings.tag_border }}; color: {{ section.settings.quote_color }};">
            {{ section.settings.product_tag }}
          </div>
        {% endif %}
      </div>
    </div>
  </section>
</div>

<style>
  #ReviewSpotlight-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .spotlight-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
    padding: 0 20px;
  }

  .spotlight-img-wrap {
    position: relative;
  }

  .spotlight-img, .spotlight-img-placeholder {
    width: 100%;
    height: 480px;
    object-fit: cover;
    border-radius: 24px;
    display: block;
    background-color: #eee;
  }

  .spotlight-product-badge {
    position: absolute;
    top: 20px;
    left: 20px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    padding: 6px 14px;
    border-radius: 50px;
  }

  .section-tag {
    display: inline-block;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 12px;
  }

  .section-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(28px, 4vw, 42px);
    font-weight: 600;
    line-height: 1.2;
    margin-bottom: 12px;
  }

  .spotlight-stars {
    font-size: 16px;
    margin-bottom: 20px;
  }

  .big-quote {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-size: clamp(18px, 2.5vw, 24px);
    line-height: 1.55;
    margin: 20px 0 30px;
    padding-left: 20px;
    border-left: 3px solid;
  }

  .spotlight-reviewer {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .spotlight-avatar, .spotlight-avatar-placeholder {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid rgba(255,255,255,0.2);
    background-color: #eee;
  }

  .spotlight-reviewer-info .name {
    font-weight: 600;
    font-size: 16px;
  }

  .spotlight-reviewer-info .meta {
    font-size: 13px;
    margin-top: 4px;
  }

  .spotlight-product-tag {
    display: inline-block;
    margin-top: 24px;
    border: 1px solid;
    font-size: 13px;
    padding: 6px 16px;
    border-radius: 50px;
  }

  @media (max-width: 960px) {
    .spotlight-inner {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .spotlight-img, .spotlight-img-placeholder {
      height: 350px;
    }
  }
</style>

{% schema %}
{
  "name": "Review Spotlight",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Background Color", "default": "#1C3A2F" },
    { "type": "image_picker", "id": "image", "label": "Spotlight Image" },
    { "type": "text", "id": "badge_text", "label": "Spotlight Badge", "default": "Editor's Pick Review" },
    { "type": "color", "id": "badge_bg", "label": "Badge BG", "default": "#D4832A" },
    { "type": "color", "id": "badge_color", "label": "Badge Text", "default": "#FFFFFF" },
    { "type": "header", "content": "Text Content" },
    { "type": "text", "id": "tag", "label": "Section Tag", "default": "Featured Review" },
    { "type": "color", "id": "tag_color", "label": "Tag Color", "default": "#F2C07A" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "A Gift That Made Her Weep Happy Tears" },
    { "type": "color", "id": "heading_color", "label": "Heading Color", "default": "#FFFFFF" },
    { "type": "text", "id": "stars", "label": "Stars Text", "default": "★★★★★" },
    { "type": "color", "id": "star_color", "label": "Star Color", "default": "#E8A020" },
    { "type": "textarea", "id": "quote", "label": "Quote", "default": "I ordered a large custom portrait of our late dog Maple as a surprise for my mom's birthday. When she unwrapped it, she sobbed — the good kind." },
    { "type": "color", "id": "quote_color", "label": "Quote/Meta Color", "default": "#E0E0E0" },
    { "type": "header", "content": "Reviewer Info" },
    { "type": "image_picker", "id": "avatar", "label": "Reviewer Avatar" },
    { "type": "text", "id": "author", "label": "Author Name", "default": "Diana L. — Verified Buyer" },
    { "type": "text", "id": "meta", "label": "Author Meta", "default": "Portland, OR · Purchased 3 months ago" },
    { "type": "text", "id": "product_tag", "label": "Product Tag", "default": "🎨 Custom Pet Portrait – Large Canvas (24×30)" },
    { "type": "color", "id": "tag_bg", "label": "Product Tag BG", "default": "rgba(255,255,255,0.08)" },
    { "type": "color", "id": "tag_border", "label": "Product Tag Border", "default": "rgba(255,255,255,0.15)" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 5, "unit": "px", "label": "Padding Top", "default": 80 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 5, "unit": "px", "label": "Padding Bottom", "default": 80 }
  ],
  "presets": [
    {
      "name": "Review Spotlight"
    }
  ]
}
{% endschema %}
