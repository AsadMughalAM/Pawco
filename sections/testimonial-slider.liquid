{% comment %}
  Section: Testimonial Slider (Playful Pawco Style)
  A smooth scrolling carousel of customer testimonials with bold playful branding.
{% endcomment %}

<div id="TestimonialSlider-{{ section.id }}" class="testimonial-slider-wrapper">
  <div class="section-inner">
    
    <div class="header-content" style="text-align: {{ section.settings.header_align }};">
      {% if section.settings.tag != blank %}
        <span class="section-tag-playful" style="background-color: {{ section.settings.tag_color }}; color: #fff;">{{ section.settings.tag }}</span>
      {% endif %}
      
      {% if section.settings.heading != blank %}
        <h2 class="section-title" style="color: {{ section.settings.heading_color }};">{{ section.settings.heading }}</h2>
      {% endif %}
      
      {% if section.settings.subtext != blank %}
        <p class="section-sub" style="color: {{ section.settings.subtext_color }};">{{ section.settings.subtext }}</p>
      {% endif %}
    </div>

    <div class="slider-container">
      <div class="slider-nav">
        <button class="nav-btn prev" aria-label="Previous">
          <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="3" fill="none"><path d="M15 18l-6-6 6-6"/></svg>
        </button>
        <button class="nav-btn next" aria-label="Next">
          <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="3" fill="none"><path d="M9 18l6-6-6-6"/></svg>
        </button>
      </div>

      <div class="testimonials-track" id="track-{{ section.id }}">
        {% for block in section.blocks %}
          <div class="testimonial-card-playful" {{ block.shopify_attributes }}>
            <div class="card-inner" style="background-color: {{ section.settings.card_bg }};">
              
              <div class="stars-row" style="color: {{ section.settings.star_color }};">
                {% for i in (1..5) %}
                  <svg class="star-icon" viewBox="0 0 24 24" fill="currentColor"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                {% endfor %}
              </div>

              <blockquote class="testimonial-quote" style="color: {{ section.settings.quote_color }};">
                "{{ block.settings.quote }}"
              </blockquote>

              <div class="testimonial-author">
                {% if block.settings.avatar != blank %}
                  <img class="author-avatar" src="{{ block.settings.avatar | image_url: width: 100 }}" alt="{{ block.settings.author }}">
                {% else %}
                  <div class="author-avatar-placeholder"></div>
                {% endif %}
                
                <div class="author-info">
                  <div class="author-name" style="color: {{ section.settings.heading_color }};">
                    {{ block.settings.author }}
                    {% if block.settings.verified %}
                      <span class="verified-tick" title="Verified Buyer">
                        <svg viewBox="0 0 24 24" fill="#4CAF50" width="16" height="16"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
                      </span>
                    {% endif %}
                  </div>
                  <div class="author-meta" style="color: {{ section.settings.subtext_color }}; opacity: 0.7;">{{ block.settings.meta }}</div>
                </div>
              </div>

              {% if block.settings.product_name != blank %}
                <div class="purchased-item" style="background-color: {{ section.settings.bg_color | color_darken: 5 }};">
                  <span class="bag-icon">🛍️</span> {{ block.settings.product_name }}
                </div>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</div>

<style>
  #TestimonialSlider-{{ section.id }} {
    --dark: #1A1A2E;
    --font-heading: 'Fredoka', 'Outfit', sans-serif;
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    padding-left: {{ section.settings.padding_left }}px;
    padding-right: {{ section.settings.padding_right }}px;
    overflow: hidden;
    position: relative;
  }

  .section-inner {
    max-width: 1400px;
    margin: 0 auto;
  }

  .header-content {
    margin-bottom: 50px;
    padding: 0 20px;
  }

  .section-tag-playful {
    display: inline-block;
    padding: 6px 15px;
    border-radius: 50px;
    font-weight: 700;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 15px;
    background-color: {{ section.settings.tag_color | color_modify: 'alpha', 0.1 }};
    color: {{ section.settings.tag_color }};
  }

  .section-title {
    font-family: var(--font-heading);
    font-size: clamp(32px, 5vw, 48px);
    font-weight: 800;
    line-height: 1.2;
    margin-bottom: 20px;
    letter-spacing: -0.5px;
  }

  .section-sub {
    font-size: 18px;
    line-height: 1.6;
    font-weight: 400;
    max-width: 650px;
    margin: 0 auto;
    opacity: 0.8;
  }

  .slider-container {
    position: relative;
    padding: 20px 0;
  }

  .slider-nav {
    position: absolute;
    top: -70px;
    right: 20px;
    display: flex;
    gap: 12px;
    z-index: 10;
  }

  .nav-btn {
    width: 45px;
    height: 45px;
    border-radius: 50%;
    background: #fff;
    border: 1px solid #eee;
    box-shadow: 0 4px 10px rgba(0,0,0,0.05);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.2s ease;
    color: var(--dark);
  }

  .nav-btn:hover {
    background: #f8f9fa;
    border-color: #ddd;
    transform: translateY(-2px);
  }

  .nav-btn:active {
    transform: translateY(0);
  }

  .testimonials-track {
    display: flex;
    gap: 25px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    padding: 20px;
    scrollbar-width: none;
    -ms-overflow-style: none;
    cursor: grab;
  }

  .testimonials-track::-webkit-scrollbar {
    display: none;
  }

  .testimonial-card-playful {
    flex: 0 0 calc((100% - ({{ section.settings.gap }}px * ({{ section.settings.cards_to_show }} - 1))) / {{ section.settings.cards_to_show }});
    scroll-snap-align: start;
    transition: transform 0.3s ease;
  }

  .card-inner {
    background: #ffffff;
    border-radius: 24px;
    padding: 40px;
    height: 100%;
    display: flex;
    flex-direction: column;
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    position: relative;
    border: 1px solid rgba(0,0,0,0.03);
  }

  .stars-row {
    display: flex;
    gap: 3px;
    margin-bottom: 20px;
  }

  .star-icon {
    width: 18px;
    height: 18px;
  }

  .testimonial-quote {
    font-size: 18px;
    line-height: 1.6;
    font-weight: 500;
    margin-bottom: 25px;
    flex-grow: 1;
    color: #444;
  }

  .testimonial-author {
    display: flex;
    align-items: center;
    gap: 15px;
    margin-bottom: 20px;
    padding-top: 20px;
    border-top: 1px solid #f0f0f0;
  }

  .author-avatar {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    object-fit: cover;
  }

  .author-avatar-placeholder {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    background: #f5f5f5;
  }

  .author-name {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: 16px;
    display: flex;
    align-items: center;
    gap: 6px;
    color: #1a243e;
  }

  .author-meta {
    font-size: 13px;
    font-weight: 400;
  }

  .purchased-item {
    padding: 8px 15px;
    border-radius: 10px;
    font-size: 12px;
    font-weight: 600;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background-color: #f8f9fa;
    color: #666;
    border: 1px solid #eee;
  }

  @media (max-width: 1024px) {
    .testimonial-card-playful {
      flex: 0 0 calc((100% - ({{ section.settings.gap }}px * 1)) / 2);
    }
  }

  @media (max-width: 768px) {
    .testimonial-card-playful {
      flex: 0 0 100%;
    }
    .slider-nav {
      top: auto;
      bottom: -70px;
      left: 50%;
      transform: translateX(-50%);
      right: auto;
    }
    #TestimonialSlider-{{ section.id }} {
      padding-bottom: 100px;
    }
    .section-title {
      font-size: 32px;
    }
  }
</style>

<script>
  function initTestimonialSlider{{ section.id | replace: '-', '_' }}() {
    const sectionId = '{{ section.id }}';
    const wrapper = document.getElementById('TestimonialSlider-' + sectionId);
    if (!wrapper) return;

    const track = wrapper.querySelector('.testimonials-track');
    const prevBtn = wrapper.querySelector('.nav-btn.prev');
    const nextBtn = wrapper.querySelector('.nav-btn.next');

    if (track && prevBtn && nextBtn) {
      const getScrollAmount = () => {
        const card = track.querySelector('.testimonial-card-playful');
        return card ? card.offsetWidth + {{ section.settings.gap }} : 400;
      };

      nextBtn.addEventListener('click', () => {
        track.scrollBy({ left: getScrollAmount(), behavior: 'smooth' });
      });

      prevBtn.addEventListener('click', () => {
        track.scrollBy({ left: -getScrollAmount(), behavior: 'smooth' });
      });

      // Drag to scroll
      let isDown = false;
      let startX;
      let scrollLeft;

      track.onmousedown = (e) => {
        isDown = true;
        track.classList.add('active');
        startX = e.pageX - track.offsetLeft;
        scrollLeft = track.scrollLeft;
        track.style.cursor = 'grabbing';
      };

      track.onmouseleave = () => {
        isDown = false;
        track.style.cursor = 'grab';
      };

      track.onmouseup = () => {
        isDown = false;
        track.style.cursor = 'grab';
      };

      track.onmousemove = (e) => {
        if (!isDown) return;
        e.preventDefault();
        const x = e.pageX - track.offsetLeft;
        const walk = (x - startX) * 2;
        track.scrollLeft = scrollLeft - walk;
      };
    }
  }

  document.addEventListener('DOMContentLoaded', initTestimonialSlider{{ section.id | replace: '-', '_' }});
  document.addEventListener('shopify:section:load', (e) => {
    if (e.detail.sectionId === '{{ section.id }}') {
      initTestimonialSlider{{ section.id | replace: '-', '_' }}();
    }
  });
</script>

{% schema %}
{
  "name": "Testimonial Slider",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Background Color", "default": "#FFFFFF" },
    { "type": "header", "content": "Header Content" },
    { "type": "text", "id": "tag", "label": "Section Tag", "default": "Customer Stories" },
    { "type": "color", "id": "tag_color", "label": "Tag Color", "default": "#1a243e" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Loved by Pets, Trusted by Parents" },
    { "type": "color", "id": "heading_color", "label": "Heading Color", "default": "#1a243e" },
    { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "See why thousands of pet owners choose Pawco for their custom pet memories." },
    { "type": "color", "id": "subtext_color", "label": "Subtext Color", "default": "#1a243e" },
    { "type": "select", "id": "header_align", "label": "Header Alignment", "options": [
      { "value": "left", "label": "Left" },
      { "value": "center", "label": "Center" }
    ], "default": "center" },
    { "type": "header", "content": "Slider Settings" },
    { "type": "range", "id": "cards_to_show", "min": 1, "max": 4, "step": 1, "label": "Cards to show (Desktop)", "default": 3 },
    { "type": "range", "id": "gap", "min": 10, "max": 50, "step": 5, "unit": "px", "label": "Gap between cards", "default": 25 },
    { "type": "header", "content": "Card Styling" },
    { "type": "color", "id": "card_bg", "label": "Card Background", "default": "#FFFFFF" },
    { "type": "color", "id": "quote_color", "label": "Quote Color", "default": "#1a243e" },
    { "type": "color", "id": "star_color", "label": "Star Color", "default": "#FFB800" },
    { "type": "header", "content": "Section Padding" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Padding Top", "default": 80 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Padding Bottom", "default": 80 },
    { "type": "range", "id": "padding_left", "min": 0, "max": 100, "step": 5, "unit": "px", "label": "Padding Left", "default": 20 },
    { "type": "range", "id": "padding_right", "min": 0, "max": 100, "step": 5, "unit": "px", "label": "Padding Right", "default": 20 }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        { "type": "textarea", "id": "quote", "label": "Quote", "default": "The portrait of my dog Buddy is absolutely stunning. It capture his personality perfectly. The quality is top-notch!" },
        { "type": "image_picker", "id": "avatar", "label": "Author Avatar" },
        { "type": "text", "id": "author", "label": "Author Name", "default": "Sarah Johnson" },
        { "type": "text", "id": "meta", "label": "Author Meta", "default": "Verified Buyer • New York, NY" },
        { "type": "checkbox", "id": "verified", "label": "Show Verified Tick", "default": true },
        { "type": "text", "id": "product_name", "label": "Product Name", "default": "Custom Oil Portrait" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonial Slider",
      "blocks": [
        { "type": "testimonial", "settings": { "author": "Sarah J.", "quote": "My dog looks like a king! The detail is incredible." } },
        { "type": "testimonial", "settings": { "author": "Mike R.", "quote": "Best gift I ever bought. My wife was in tears!" } },
        { "type": "testimonial", "settings": { "author": "Emma L.", "quote": "Fast shipping and amazing customer support. 10/10!" } },
        { "type": "testimonial", "settings": { "author": "David W.", "quote": "The canvas quality is much better than other sites I've tried." } }
      ]
    }
  ]
}
{% endschema %}
