{%- style -%}
  .terms-hero-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    text-align: center;
  }
  .terms-hero__inner-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    max-width: {{ section.settings.content_width }}px;
    margin: 0 auto;
    padding: {{ section.settings.inner_padding }}px 20px;
    border-radius: {{ section.settings.border_radius }}px {{ section.settings.border_radius }}px 0 0;
    border-top: 1px solid {{ section.settings.border_color }};
    border-left: 1px solid {{ section.settings.border_color }};
    border-right: 1px solid {{ section.settings.border_color }};
    overflow: hidden;
  }
  .terms-hero-{{ section.id }} h1 {
    color: {{ section.settings.text_color }};
    margin: 0;
    font-size: {{ section.settings.font_size }}px;
    text-transform: uppercase;
    letter-spacing: 2px;
    font-weight: 700;
  }
  @media screen and (max-width: 749px) {
    .terms-hero-{{ section.id }} h1 {
      font-size: {{ section.settings.font_size | times: 0.7 }}px;
    }
    .terms-hero__inner-{{ section.id }} {
      padding: {{ section.settings.inner_padding | times: 0.7 | round }}px 15px;
    }
  }
{%- endstyle -%}

<div class="terms-hero terms-hero-{{ section.id }}">
  <div class="page-width">
    <div class="terms-hero__inner-{{ section.id }}">
      <h1>{{ section.settings.title }}</h1>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Terms Hero",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Terms & Conditions"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#1a243e"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border Color",
      "default": "#e0e0e0"
    },
    {
      "type": "range",
      "id": "content_width",
      "label": "Content Max Width",
      "min": 400,
      "max": 1200,
      "step": 20,
      "unit": "px",
      "default": 800
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border Radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font Size",
      "min": 20,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "inner_padding",
      "label": "Banner Vertical Padding",
      "min": 20,
      "max": 200,
      "step": 5,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Terms Hero"
    }
  ]
}
{% endschema %}
